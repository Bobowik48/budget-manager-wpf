<Window x:Class="BudgetManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:BudgetManager.ViewModels"
        mc:Ignorable="d"
        Title="Budget Manager"
        Height="760" Width="1280"
        MinHeight="680" MinWidth="1050"
        Background="#F5F7FA">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="FormField" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#2563EB"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#2563EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FormCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="BorderBrush" Value="#DC2626"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B91C1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IncomeRow" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Type}" Value="Przychód">
                    <Setter Property="Foreground" Value="#15803D"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- NAGŁÓWEK -->
        <Border Grid.Row="0" Background="#1F2937" CornerRadius="14" Padding="22,16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="💰 Budget Manager"
                               FontSize="26" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Aplikacja do zarządzania budżetem domowym"
                               FontSize="13" Foreground="#9CA3AF" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="💾  Zapisz dane"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Height="36" Padding="16,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- KARTY STATYSTYK -->
        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="18,14"
                    Margin="0,0,8,0" BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Aktualny bilans" FontSize="12" Foreground="#6B7280"/>
                    <TextBlock Text="{Binding Balance, StringFormat={}{0:N2} zł}"
                               FontSize="24" FontWeight="Bold" Foreground="#111827" Margin="0,6,0,0"/>
                    <TextBlock Text="{Binding SummaryLabel}"
                               FontSize="11" Foreground="#9CA3AF" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="18,14"
                    Margin="8,0,8,0" BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Suma przychodów" FontSize="12" Foreground="#6B7280"/>
                    <TextBlock Text="{Binding IncomeSummary, StringFormat={}{0:N2} zł}"
                               FontSize="24" FontWeight="Bold" Foreground="#15803D" Margin="0,6,0,0"/>
                    <TextBlock Text="{Binding SummaryLabel}"
                               FontSize="11" Foreground="#9CA3AF" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="18,14"
                    Margin="8,0,0,0" BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Suma wydatków" FontSize="12" Foreground="#6B7280"/>
                    <TextBlock Text="{Binding ExpensesSummary, StringFormat={}{0:N2} zł}"
                               FontSize="24" FontWeight="Bold" Foreground="#B91C1C" Margin="0,6,0,0"/>
                    <TextBlock Text="{Binding SummaryLabel}"
                               FontSize="11" Foreground="#9CA3AF" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- PASEK FILTRÓW -->
        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="14,10"
                Margin="0,0,0,14" BorderBrush="#E5E7EB" BorderThickness="1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Filtruj:" FontWeight="SemiBold" FontSize="13"
                           VerticalAlignment="Center" Margin="0,0,12,0" Foreground="#374151"/>
                <TextBlock Text="Miesiąc:" FontSize="12" Foreground="#6B7280"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox ItemsSource="{Binding AvailableMonths}"
                          SelectedItem="{Binding SelectedMonth}"
                          DisplayMemberPath="Label"
                          Width="180" Height="32"
                          Style="{StaticResource FormCombo}"
                          Margin="0,0,20,0"/>
                <TextBlock Text="Typ:" FontSize="12" Foreground="#6B7280"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox ItemsSource="{Binding TypeFilters}"
                          SelectedItem="{Binding SelectedTypeFilter}"
                          Width="130" Height="32"
                          Style="{StaticResource FormCombo}"/>
            </StackPanel>
        </Border>

        <!-- LISTA + FORMULARZ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Lista transakcji -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="18"
                    BorderBrush="#E5E7EB" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Lista transakcji"
                                   FontSize="18" FontWeight="SemiBold" Foreground="#111827"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Transactions.Count, StringFormat={}{0} pozycji}"
                                   FontSize="12" Foreground="#6B7280" Grid.Column="1"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Transactions}"
                              SelectedItem="{Binding SelectedTransaction}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" Background="White"
                              BorderThickness="0" RowHeaderWidth="0"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              RowStyle="{StaticResource IncomeRow}"
                              SelectionMode="Single" FontSize="13">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F9FAFB"/>
                                <Setter Property="Foreground" Value="#6B7280"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="8,8"/>
                                <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Data"
                                               Binding="{Binding Date, StringFormat=dd.MM.yyyy}"
                                               Width="100"/>
                            <DataGridTextColumn Header="Typ"
                                               Binding="{Binding Type}" Width="95"/>
                            <DataGridTextColumn Header="Kategoria"
                                               Binding="{Binding Category}" Width="140"/>
                            <DataGridTextColumn Header="Kwota"
                                               Binding="{Binding Amount, StringFormat={}{0:N2} zł}"
                                               Width="110"/>
                            <DataGridTextColumn Header="Opis"
                                               Binding="{Binding Description}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,14,0,0">
                        <Button Content="🔍  Podgląd" Command="{Binding PreviewCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Width="110" Height="34" Padding="0" Margin="0,0,8,0"/>
                        <Button Content="✏️  Edytuj" Command="{Binding EditCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Width="110" Height="34" Padding="0" Margin="0,0,8,0"/>
                        <Button Content="🗑️  Usuń" Command="{Binding DeleteCommand}"
                                Style="{StaticResource DangerButton}"
                                Width="110" Height="34" Padding="0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Formularz -->
            <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="18"
                    BorderBrush="#E5E7EB" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Formularz transakcji"
                                   FontSize="18" FontWeight="SemiBold" Foreground="#111827"
                                   Margin="0,0,0,18"/>

                        <!-- Kwota + walidacja -->
                        <TextBlock Text="Kwota (zł) *" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,2">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource FormField}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasAmountError}" Value="True">
                                            <Setter Property="BorderBrush" Value="#DC2626"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <TextBlock Text="{Binding AmountError}"
                                   Foreground="#DC2626" FontSize="11" Margin="0,0,0,10">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasAmountError}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Data -->
                        <TextBlock Text="Data *" Style="{StaticResource FormLabel}"/>
                        <DatePicker SelectedDate="{Binding NewTransaction.Date}"
                                    Height="36" Margin="0,0,0,14" FontSize="13"/>

                        <!-- Typ -->
                        <TextBlock Text="Typ transakcji *" Style="{StaticResource FormLabel}"/>
                        <ComboBox SelectedItem="{Binding SelectedType}"
                                  ItemsSource="{Binding TypeOptions}"
                                  Style="{StaticResource FormCombo}" Margin="0,0,0,14"/>

                        <!-- Kategoria -->
                        <TextBlock Text="Kategoria *" Style="{StaticResource FormLabel}"/>
                        <ComboBox SelectedItem="{Binding SelectedCategory}"
                                  ItemsSource="{Binding CategoryOptions}"
                                  Style="{StaticResource FormCombo}" Margin="0,0,0,14"/>

                        <!-- Opis -->
                        <TextBlock Text="Opis *" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding NewTransaction.Description, UpdateSourceTrigger=PropertyChanged}"
                                 Height="90" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalContentAlignment="Top" Padding="10,8"
                                 BorderBrush="#D1D5DB" FontSize="13" Margin="0,0,0,20"/>

                        <!-- Przyciski -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="✅  Dodaj / Zapisz"
                                    Command="{Binding AddCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Height="38" Padding="0" FontSize="13"/>
                            <Button Grid.Column="2" Content="🔄  Wyczyść"
                                    Command="{Binding ClearCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="38" Padding="0" FontSize="13"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>