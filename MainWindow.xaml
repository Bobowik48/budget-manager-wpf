<Window x:Class="BudgetManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Budget Manager"
        Height="720"
        Width="1200"
        MinHeight="650"
        MinWidth="1000"
        Background="#F5F7FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#1F2937"
                CornerRadius="14"
                Padding="20"
                Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Budget Manager"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="Aplikacja do zarządzania budżetem domowym"
                           Margin="0,6,0,0"
                           FontSize="14"
                           Foreground="#D1D5DB"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="12"
                    Padding="18"
                    Margin="0,0,10,0"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Aktualny bilans"
                               FontSize="14"
                               Foreground="#6B7280"/>
                    <TextBlock x:Name="BalanceTextBlock"
                               Text="0,00 zł"
                               Margin="0,8,0,0"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#111827"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="12"
                    Padding="18"
                    Margin="10,0,10,0"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Suma przychodów"
                               FontSize="14"
                               Foreground="#6B7280"/>
                    <TextBlock x:Name="IncomeTextBlock"
                               Text="0,00 zł"
                               Margin="0,8,0,0"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#15803D"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="12"
                    Padding="18"
                    Margin="10,0,0,0"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Suma wydatków"
                               FontSize="14"
                               Foreground="#6B7280"/>
                    <TextBlock x:Name="ExpensesTextBlock"
                               Text="0,00 zł"
                               Margin="0,8,0,0"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#B91C1C"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="12"
                    Padding="18"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Lista transakcji"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#111827"
                               Margin="0,0,0,12"/>

                    <DataGrid Grid.Row="1"
                              x:Name="TransactionsDataGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              Background="White"
                              BorderThickness="0"
                              RowHeaderWidth="0"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Data"
                                                Binding="{Binding Date, StringFormat=dd.MM.yyyy}"
                                                Width="110"/>
                            <DataGridTextColumn Header="Typ"
                                                Binding="{Binding Type}"
                                                Width="110"/>
                            <DataGridTextColumn Header="Kategoria"
                                                Binding="{Binding Category}"
                                                Width="140"/>
                            <DataGridTextColumn Header="Kwota"
                                                Binding="{Binding Amount, StringFormat={}{0:N2} zł}"
                                                Width="120"/>
                            <DataGridTextColumn Header="Opis"
                                                Binding="{Binding Description}"
                                                Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,14,0,0">
                        <Button Content="Podgląd"
                                Width="110"
                                Height="36"
                                Margin="0,0,10,0"/>
                        <Button Content="Edytuj"
                                Width="110"
                                Height="36"
                                Margin="0,0,10,0"/>
                        <Button Content="Usuń"
                                Width="110"
                                Height="36"
                                Background="#DC2626"
                                Foreground="White"
                                BorderBrush="#DC2626"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="12"
                    Padding="18"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Formularz transakcji"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   Margin="0,0,0,16"/>

                        <TextBlock Text="Kwota"
                                   Margin="0,0,0,6"
                                   FontWeight="SemiBold"/>
                        <TextBox x:Name="AmountTextBox"
                                 Height="34"
                                 Margin="0,0,0,14"/>

                        <TextBlock Text="Data"
                                   Margin="0,0,0,6"
                                   FontWeight="SemiBold"/>
                        <DatePicker x:Name="TransactionDatePicker"
                                    Height="34"
                                    Margin="0,0,0,14"/>

                        <TextBlock Text="Typ transakcji"
                                   Margin="0,0,0,6"
                                   FontWeight="SemiBold"/>
                        <ComboBox x:Name="TypeComboBox"
                                  Height="34"
                                  Margin="0,0,0,14">
                            <ComboBoxItem Content="Przychód"/>
                            <ComboBoxItem Content="Wydatek"/>
                        </ComboBox>

                        <TextBlock Text="Kategoria"
                                   Margin="0,0,0,6"
                                   FontWeight="SemiBold"/>
                        <ComboBox x:Name="CategoryComboBox"
                                  Height="34"
                                  Margin="0,0,0,14">
                            <ComboBoxItem Content="Wynagrodzenie"/>
                            <ComboBoxItem Content="Zakupy spożywcze"/>
                            <ComboBoxItem Content="Transport"/>
                            <ComboBoxItem Content="Rachunki"/>
                            <ComboBoxItem Content="Rozrywka"/>
                            <ComboBoxItem Content="Sport"/>
                            <ComboBoxItem Content="Inne"/>
                        </ComboBox>

                        <TextBlock Text="Opis"
                                   Margin="0,0,0,6"
                                   FontWeight="SemiBold"/>
                        <TextBox x:Name="DescriptionTextBox"
                                 Height="90"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top"
                                 Margin="0,0,0,20"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Stretch">
                            <Button Content="Dodaj"
                                    Height="38"
                                    Width="100"
                                    Margin="0,0,10,0"
                                    Background="#2563EB"
                                    Foreground="White"
                                    BorderBrush="#2563EB"/>
                            <Button Content="Wyczyść"
                                    Height="38"
                                    Width="100"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>